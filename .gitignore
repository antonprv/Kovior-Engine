# Sandbox binaries and assets

# Compiled/cached asset files (generated by Sandbox engine)
*_c
*.vtex_c
*.vmat_c
*.vmdl_c
*.vanmgrph_c
*.vmap_c
*.vpcf_c
*.vmdl_snapshots
*.vmat_snapshots

# Shader cache
game/core/shadercache/
**/shaders.cache
**/*.shadercache

# Generated texture files
**/generated/**/*.vtex_c
**/generated/imagefile/*.vtex_c
**/generated/svgsource/*.vtex_c

# Transient build artifacts
**/Transients/

# Runtime config files
*.runtimeconfig.json
*.deps.json

# Intermediate build output
*.pdb
*.dll
*.exe

# Editor thumbnails
*_thumbnail_*

# Scene/object cache
*.scene_c
*.prefab_c

# Material variants
*.vmat

# Map compilation artifacts
*.vmap

# Font cache
*.fontconfig

# Particle system cache
*.vpcf

